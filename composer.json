{
    "name": "phantomshift/laravel-deployer",
    "description": "Zero downtime Blue-Green deployment for Laravel",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Phantomshift\\LaravelDeployer\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Phantomshift\\LaravelDeployer\\LaravelDeployerServiceProvider"
            ]
        }
    }
}